# Yahoo Mail MCP Server Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!

# =============================================================================
# TRANSPORT MODE
# =============================================================================

# stdio = local desktop use with app password
# sse   = remote Claude connector use with Yahoo OAuth
TRANSPORT_MODE=sse
PORT=3000

# Optional but recommended in production
PUBLIC_BASE_URL=http://localhost:3000

# =============================================================================
# REMOTE YAHOO OAUTH MODE (recommended for Claude connector)
# =============================================================================

# Yahoo developer app credentials
YAHOO_CLIENT_ID=your-yahoo-client-id
YAHOO_CLIENT_SECRET=your-yahoo-client-secret

# Minimal delegated scopes for remote auth
YAHOO_SCOPES=openid email

# =============================================================================
# LOCAL STDIO MODE (legacy / local only)
# =============================================================================

# Your Yahoo Mail email address
YAHOO_EMAIL=your.email@yahoo.com

# Yahoo Mail app-specific password (16 characters)
# Generate at: https://login.yahoo.com/account/security/app-passwords
YAHOO_APP_PASSWORD=your16charpassword
